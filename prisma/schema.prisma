generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Profile {
  id            String   @id @default(uuid()) @db.Uuid
  email         String?  @unique
  linkedin_slug String?  @unique
  linkedin_url  String?  @unique
  phone_e164    String?  @unique
  data          Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @updatedAt @db.Timestamptz(6)

  client_links  ContactClient[]

  @@index([email])
  @@index([linkedin_slug])
  @@index([linkedin_url])
  @@index([phone_e164])
  @@map("profiles")
}

model Company {
  id            String   @id @default(uuid()) @db.Uuid
  domain        String?  @unique
  linkedin_slug String?  @unique
  data          Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @updatedAt @db.Timestamptz(6)

  @@index([domain])
  @@index([linkedin_slug])
  @@map("companies")
}

// ─── Email Cache ────────────────────────────────────────────

model VerificationCache {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  status      String
  confidence  Float    @default(0.0)
  method      String?
  verified_at DateTime @default(now()) @db.Timestamptz(6)
  expires_at  DateTime @db.Timestamptz(6)

  @@index([email])
  @@map("verification_cache")
}

model DomainIntel {
  id               String   @id @default(uuid()) @db.Uuid
  domain           String   @unique
  has_mx           Boolean  @default(false)
  mx_records       Json     @default("[]")
  provider         String   @default("other")
  is_catch_all     Boolean  @default(false)
  is_disposable    Boolean  @default(false)
  is_free_provider Boolean  @default(false)
  checked_at       DateTime @default(now()) @db.Timestamptz(6)
  expires_at       DateTime @db.Timestamptz(6)

  @@index([domain])
  @@map("domain_intel")
}

// ─── Do Not Contact (multi-tenant) ──────────────────────────

// A customer/tenant. `external_id` is the value passed in API payloads
// (e.g. "client_id"). HubSpot credentials are optional and only needed
// for clients that sync DNC data from HubSpot lists.
model Client {
  id                   String   @id @default(uuid()) @db.Uuid
  external_id          String   @unique
  name                 String
  active               Boolean  @default(true)
  // HubSpot portal id. Tokens are NEVER stored — they are resolved fresh from
  // the provisioner (see hubspot-token.service). Identity (slug/name/portal) is
  // sourced from GTMOS via the internal API (see sdr-launch.service), not held
  // authoritatively here.
  hubspot_portal_id    String?
  // DEPRECATED: never written or returned (stripped in publicClient). Retained as
  // a column only so the deploy-time `prisma db push` stays non-destructive (the
  // start script has no --accept-data-loss). Drop in a deliberate follow-up:
  //   ALTER TABLE clients DROP COLUMN hubspot_access_token;  (then remove here)
  hubspot_access_token String?
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @updatedAt @db.Timestamptz(6)

  dnc_sources         DncSource[]
  dnc_entries         DncEntry[]
  phoneburner_members PhoneburnerMember[]
  contact_links       ContactClient[]

  @@index([external_id])
  @@map("clients")
}

// ─── Contact ↔ Customer association (Phase 3) ───────────────────────────────
// The bridge that makes the global, deduplicated contact database multi-tenant:
// one canonical Profile can belong to many customers. This is what lets us build
// a per-customer TAM list, attribute enrichment to the customers that paid for
// it, and measure cross-customer reuse (a contact linked to ≥2 clients = an
// enrichment credit we didn't spend twice).
model ContactClient {
  id              String   @id @default(uuid()) @db.Uuid
  contact_id      String   @db.Uuid
  contact         Profile  @relation(fields: [contact_id], references: [id], onDelete: Cascade)
  client_id       String   @db.Uuid
  client          Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  // How this contact entered the customer's universe: 'enriched' (we paid to
  // enrich it for them), 'pushed' (we pushed it to their CRM), 'imported', 'manual'.
  source          String   @default("manual")
  // Cheapest provenance for the credit-savings story: was enrichment data
  // already cached when this customer asked for it?
  reused_cache    Boolean  @default(false)
  first_seen_at   DateTime @default(now()) @db.Timestamptz(6)
  last_enriched_at DateTime? @db.Timestamptz(6)

  // ─── Push-to-CRM state (Phase 4) ──────────────────────────────────────────
  // A lead pushed via POST /admin/hubspot/contacts is recorded here. When the
  // customer's CRM isn't connected yet (no portal, or access not granted), the
  // push is stored as 'pending' instead of erroring — we routinely build a list
  // weeks before receiving HubSpot access. POST /admin/hubspot/backfill later
  // replays every non-'pushed' lead once access arrives.
  //   null        — link not created by a push (e.g. a plain associate()).
  //   'pending'   — stored, CRM not reachable yet; awaiting backfill.
  //   'pushed'    — live in the CRM (hubspot_contact_id set).
  //   'failed'    — push attempted, transient/other error; backfill will retry.
  //   'skipped_dnc' — suppressed by the client's DNC list; not pushed.
  push_status          String?
  // Exact CRM properties captured at request time, replayed verbatim on backfill.
  push_properties      Json?
  // Whether to re-enforce DNC when (re)pushing this lead.
  push_check_dnc       Boolean   @default(true)
  hubspot_contact_id   String?
  push_attempts        Int       @default(0)
  push_error           String?
  last_push_attempt_at DateTime? @db.Timestamptz(6)

  @@unique([contact_id, client_id])
  @@index([client_id])
  @@index([contact_id])
  @@index([client_id, push_status])
  @@map("contact_clients")
}

// Where a client's DNC entries come from: an uploaded CSV or a HubSpot list.
// HubSpot sources are re-synced (full snapshot) on a schedule; their entries
// are replaced wholesale on each sync.
model DncSource {
  id               String    @id @default(uuid()) @db.Uuid
  client_id        String    @db.Uuid
  client           Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  type             String    // 'csv' | 'hubspot_list'
  // Suppression level for a HubSpot-list source:
  //   'individual' — exact email/phone match only.
  //   'domain'     — also suppresses each member's (corporate) email domain.
  // CSV sources keep the default; they carry whatever identifiers the file has.
  dnc_level        String    @default("individual")
  label            String?
  hubspot_list_id  String?   // for type = 'hubspot_list'
  active           Boolean   @default(true)
  last_synced_at   DateTime? @db.Timestamptz(6)
  last_sync_status String?   // 'ok' | 'error'
  last_sync_error  String?
  last_entry_count Int       @default(0)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @updatedAt @db.Timestamptz(6)

  entries DncEntry[]

  // Prevents duplicate HubSpot-list sources per client.
  // (CSV sources have a null hubspot_list_id; Postgres treats nulls as
  // distinct, so multiple CSV sources per client are allowed.)
  @@unique([client_id, hubspot_list_id])
  @@index([client_id])
  @@map("dnc_sources")
}

// A single suppressed contact for a client. A row may carry any combination
// of email / phone / domain; the check matches on ANY provided identifier.
model DncEntry {
  id          String     @id @default(uuid()) @db.Uuid
  client_id   String     @db.Uuid
  client      Client     @relation(fields: [client_id], references: [id], onDelete: Cascade)
  source_id   String?    @db.Uuid
  source      DncSource? @relation(fields: [source_id], references: [id], onDelete: Cascade)
  source_type String     // 'csv' | 'hubspot_list' | 'manual'

  email      String?
  phone_e164 String?
  domain     String?

  reason     String?
  data       Json     @default("{}") // extra context (hubspot contact id, raw row, etc)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@index([client_id, email])
  @@index([client_id, phone_e164])
  @@index([client_id, domain])
  @@index([source_id])
  @@map("dnc_entries")
}

// ─── PhoneBurner DNC purge (see PHONEBURNER_DNC_PURGE_PLAN.md) ───────────────

// Which PhoneBurner members dial for which client. Populated from the SDR Launch
// join (calls -> sdrs.provider_user_ids.phoneburner). Tokens are NEVER stored —
// resolved at runtime from the admin token (PHONEBURNER_ADMIN_TOKEN).
model PhoneburnerMember {
  id            String    @id @default(uuid()) @db.Uuid
  client_id     String    @db.Uuid
  client        Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  pb_member_id  String // PhoneBurner user_id
  pb_username   String? // email, for logs
  active        Boolean   @default(true) // false = stop scrubbing (left team / API off)
  api_access_ok Boolean   @default(false) // last run saw a working token (else 403)
  last_run_at   DateTime? @db.Timestamptz(6)
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @updatedAt @db.Timestamptz(6)

  @@unique([client_id, pb_member_id])
  @@index([client_id])
  @@map("phoneburner_members")
}

// Audit + backup of every deletion. `snapshot` holds the full PB contact JSON so
// a delete is re-importable. Doubles as idempotency + reporting.
model PhoneburnerDeletion {
  id            String   @id @default(uuid()) @db.Uuid
  client_id     String   @db.Uuid
  pb_member_id  String
  pb_contact_id String
  matched_on    String // 'email' | 'phone' | 'domain' (+combos)
  matched_value String?
  snapshot      Json     @default("{}") // full contact record at delete time
  status        String // 'deleted' | 'failed' | 'dry_run'
  http_status   Int?
  error         String?
  run_id        String?  @db.Uuid
  deleted_at    DateTime @default(now()) @db.Timestamptz(6)

  @@index([client_id, pb_contact_id])
  @@index([run_id])
  @@map("phoneburner_deletions")
}

// One row per cron run (observability + alerting).
model PhoneburnerPurgeRun {
  id                String    @id @default(uuid()) @db.Uuid
  started_at        DateTime  @default(now()) @db.Timestamptz(6)
  finished_at       DateTime? @db.Timestamptz(6)
  dry_run           Boolean   @default(false)
  clients_processed Int       @default(0)
  members_processed Int       @default(0)
  members_skipped   Int       @default(0) // API access off, no token, aborted by gate
  contacts_scanned  Int       @default(0)
  collisions_found  Int       @default(0)
  deleted           Int       @default(0)
  failed            Int       @default(0)
  status            String    @default("running") // running | ok | partial | error
  notes             String?

  @@map("phoneburner_purge_runs")
}
