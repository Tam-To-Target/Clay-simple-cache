generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Profile {
  id            String   @id @default(uuid()) @db.Uuid
  email         String?  @unique
  linkedin_slug String?  @unique
  linkedin_url  String?  @unique
  phone_e164    String?  @unique
  data          Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @updatedAt @db.Timestamptz(6)

  @@index([email])
  @@index([linkedin_slug])
  @@index([linkedin_url])
  @@index([phone_e164])
  @@map("profiles")
}

model Company {
  id            String   @id @default(uuid()) @db.Uuid
  domain        String?  @unique
  linkedin_slug String?  @unique
  data          Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @updatedAt @db.Timestamptz(6)

  @@index([domain])
  @@index([linkedin_slug])
  @@map("companies")
}

// ─── Email Cache ────────────────────────────────────────────

model VerificationCache {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  status      String
  confidence  Float    @default(0.0)
  method      String?
  verified_at DateTime @default(now()) @db.Timestamptz(6)
  expires_at  DateTime @db.Timestamptz(6)

  @@index([email])
  @@map("verification_cache")
}

model DomainIntel {
  id               String   @id @default(uuid()) @db.Uuid
  domain           String   @unique
  has_mx           Boolean  @default(false)
  mx_records       Json     @default("[]")
  provider         String   @default("other")
  is_catch_all     Boolean  @default(false)
  is_disposable    Boolean  @default(false)
  is_free_provider Boolean  @default(false)
  checked_at       DateTime @default(now()) @db.Timestamptz(6)
  expires_at       DateTime @db.Timestamptz(6)

  @@index([domain])
  @@map("domain_intel")
}

// ─── Do Not Contact (multi-tenant) ──────────────────────────

// A customer/tenant. `external_id` is the value passed in API payloads
// (e.g. "client_id"). HubSpot credentials are optional and only needed
// for clients that sync DNC data from HubSpot lists.
model Client {
  id                   String   @id @default(uuid()) @db.Uuid
  external_id          String   @unique
  name                 String
  active               Boolean  @default(true)
  // HubSpot private-app token used to read the client's lists.
  // NOTE: stored as provided — protect DB access accordingly.
  hubspot_portal_id    String?
  hubspot_access_token String?
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @updatedAt @db.Timestamptz(6)

  dnc_sources DncSource[]
  dnc_entries DncEntry[]

  @@index([external_id])
  @@map("clients")
}

// Where a client's DNC entries come from: an uploaded CSV or a HubSpot list.
// HubSpot sources are re-synced (full snapshot) on a schedule; their entries
// are replaced wholesale on each sync.
model DncSource {
  id               String    @id @default(uuid()) @db.Uuid
  client_id        String    @db.Uuid
  client           Client    @relation(fields: [client_id], references: [id], onDelete: Cascade)
  type             String    // 'csv' | 'hubspot_list'
  // Suppression level for a HubSpot-list source:
  //   'individual' — exact email/phone match only.
  //   'domain'     — also suppresses each member's (corporate) email domain.
  // CSV sources keep the default; they carry whatever identifiers the file has.
  dnc_level        String    @default("individual")
  label            String?
  hubspot_list_id  String?   // for type = 'hubspot_list'
  active           Boolean   @default(true)
  last_synced_at   DateTime? @db.Timestamptz(6)
  last_sync_status String?   // 'ok' | 'error'
  last_sync_error  String?
  last_entry_count Int       @default(0)
  created_at       DateTime  @default(now()) @db.Timestamptz(6)
  updated_at       DateTime  @updatedAt @db.Timestamptz(6)

  entries DncEntry[]

  // Prevents duplicate HubSpot-list sources per client.
  // (CSV sources have a null hubspot_list_id; Postgres treats nulls as
  // distinct, so multiple CSV sources per client are allowed.)
  @@unique([client_id, hubspot_list_id])
  @@index([client_id])
  @@map("dnc_sources")
}

// A single suppressed contact for a client. A row may carry any combination
// of email / phone / domain; the check matches on ANY provided identifier.
model DncEntry {
  id          String     @id @default(uuid()) @db.Uuid
  client_id   String     @db.Uuid
  client      Client     @relation(fields: [client_id], references: [id], onDelete: Cascade)
  source_id   String?    @db.Uuid
  source      DncSource? @relation(fields: [source_id], references: [id], onDelete: Cascade)
  source_type String     // 'csv' | 'hubspot_list' | 'manual'

  email      String?
  phone_e164 String?
  domain     String?

  reason     String?
  data       Json     @default("{}") // extra context (hubspot contact id, raw row, etc)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @updatedAt @db.Timestamptz(6)

  @@index([client_id, email])
  @@index([client_id, phone_e164])
  @@index([client_id, domain])
  @@index([source_id])
  @@map("dnc_entries")
}
