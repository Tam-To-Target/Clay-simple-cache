generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  id            String   @id @default(uuid()) @db.Uuid
  email         String?  @unique
  linkedin_slug String?  @unique
  linkedin_url  String?  @unique
  phone_e164    String?  @unique
  data          Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @updatedAt @db.Timestamptz(6)

  @@index([email])
  @@index([linkedin_slug])
  @@index([linkedin_url])
  @@index([phone_e164])
  @@map("profiles")
}

model Company {
  id            String   @id @default(uuid()) @db.Uuid
  domain        String?  @unique
  linkedin_slug String?  @unique
  data          Json     @default("{}")
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @updatedAt @db.Timestamptz(6)

  @@index([domain])
  @@index([linkedin_slug])
  @@map("companies")
}

// ─── Email Finder ───────────────────────────────────────────

model VerificationCache {
  id          String   @id @default(uuid()) @db.Uuid
  email       String   @unique
  status      String
  confidence  Float    @default(0.0)
  method      String?
  verified_at DateTime @default(now()) @db.Timestamptz(6)
  expires_at  DateTime @db.Timestamptz(6)

  @@index([email])
  @@map("verification_cache")
}

model DomainPattern {
  id             String   @id @default(uuid()) @db.Uuid
  domain         String
  pattern        String
  confidence     Float    @default(1.0)
  sample_count   Int      @default(1)
  last_confirmed DateTime @default(now()) @db.Timestamptz(6)

  @@unique([domain, pattern])
  @@index([domain])
  @@map("domain_patterns")
}

model DomainIntel {
  id               String   @id @default(uuid()) @db.Uuid
  domain           String   @unique
  has_mx           Boolean  @default(false)
  mx_records       Json     @default("[]")
  provider         String   @default("other")
  is_catch_all     Boolean  @default(false)
  is_disposable    Boolean  @default(false)
  is_free_provider Boolean  @default(false)
  checked_at       DateTime @default(now()) @db.Timestamptz(6)
  expires_at       DateTime @db.Timestamptz(6)

  @@index([domain])
  @@map("domain_intel")
}

model SearchLog {
  id                 String   @id @default(uuid()) @db.Uuid
  first_name         String?
  last_name          String?
  domain             String?
  result_email       String?
  result_status      String?
  method_used        String?
  permutations_tried Int      @default(0)
  api_calls_made     Int      @default(0)
  cost_usd           Float    @default(0.0)
  duration_ms        Int      @default(0)
  created_at         DateTime @default(now()) @db.Timestamptz(6)

  @@index([domain])
  @@map("search_log")
}
