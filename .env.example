PORT=3000
API_KEY=your_secret_api_key_here
# Max JSON request body (CSV DNC imports can be large). Default 10mb.
JSON_BODY_LIMIT=10mb

# DATABASE_URL: Neon Postgres connection string (sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# ─── Multi-tenant DNC sync ──────────────────────────────────
# Tokens DB: where HubSpot OAuth tokens live (read-only; one row per portal).
HUBSPOT_TOKES_DATABASE_URL="postgresql://user:password@host:port/railway"
# Provisioner: transparently refreshes + returns a valid HubSpot token per portal.
HUBSPOT_PROVISIONER_URL="https://hubspot-provisioner-production.up.railway.app"
HUBSPOT_PROVISIONER_API_SECRET=your_internal_api_secret_here
# List name to discover in each portal (each portal may have an Individual + a Domain list).
DNC_LIST_NAME_PREFIX="TAM - Do Not Contact"
# GTMOS (SDR Launch) internal API — the source of customer identity + access +
# SDR→PhoneBurner mapping + user-token introspection. Replaces the old direct
# SDR_LAUNCH_DATABASE_URL connection. The secret must equal GTMOS's
# CONTACT_PLATFORM_INTERNAL_SECRET.
SDR_LAUNCH_INTERNAL_URL="https://web-production-b954c.up.railway.app"
SDR_LAUNCH_INTERNAL_SECRET=your_gtmos_internal_secret_here
# How far back (days) the registry generator looks in the call log for active
# client↔SDR dialing pairs (used to map PhoneBurner members). Default 120.
PB_MAP_CALL_WINDOW_DAYS=120

# ─── PhoneBurner DNC purge (see PHONEBURNER_DNC_PURGE_PLAN.md) ──────────────
# Durable admin (BOBBY) bearer token — resolves every member token at runtime.
PHONEBURNER_ADMIN_TOKEN=your_phoneburner_admin_bearer_token
PHONEBURNER_API_BASE="https://www.phoneburner.com/rest/1"
PHONEBURNER_USER_AGENT="TAM-DNC-Cache/1.0"
# SAFETY: dry-run unless explicitly "false". Keep true until validated in prod.
PB_PURGE_DRY_RUN=true
# Abort a member's deletes if collisions exceed this fraction of its book.
PB_PURGE_MAX_RATIO=0.40
# Also suppress by corporate email domain (not just exact email/phone).
PB_PURGE_INCLUDE_DOMAINS=true
# Optional circuit breaker: max deletes across a whole run (blank = unlimited).
PB_PURGE_MAX_DELETES_PER_RUN=

# Email Cache — Verification API Keys
EMAILLISTVERIFY_API_KEY=your_emaillistverify_key_here
DEBOUNCE_API_KEY=your_debounce_key_here

# LinkedIn Finder — SERP lookups (google.serper.dev)
SERPER_API_KEY=your_serper_key_here
