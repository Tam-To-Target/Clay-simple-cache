PORT=3000
API_KEY=your_secret_api_key_here

# DATABASE_URL: Neon Postgres connection string (sslmode=require)
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require"

# ─── Multi-tenant DNC sync ──────────────────────────────────
# Tokens DB: where HubSpot OAuth tokens live (read-only; one row per portal).
HUBSPOT_TOKES_DATABASE_URL="postgresql://user:password@host:port/railway"
# Provisioner: transparently refreshes + returns a valid HubSpot token per portal.
HUBSPOT_PROVISIONER_URL="https://hubspot-provisioner-production.up.railway.app"
HUBSPOT_PROVISIONER_API_SECRET=your_internal_api_secret_here
# List name to discover in each portal (each portal may have an Individual + a Domain list).
DNC_LIST_NAME_PREFIX="TAM - Do Not Contact"
# Read-only join source for `npm run clients:generate` (portal_id -> client slug). Not used at runtime.
SDR_LAUNCH_DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Email Cache — Verification API Keys
EMAILLISTVERIFY_API_KEY=your_emaillistverify_key_here
DEBOUNCE_API_KEY=your_debounce_key_here

# LinkedIn Finder — SERP lookups (google.serper.dev)
SERPER_API_KEY=your_serper_key_here
